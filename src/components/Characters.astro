---
import charactersData from "../data/characters.json";
const { sectionHeader, characters } = charactersData;
---

<section
  id="characters"
  class="py-12 md:py-16 px-4 md:px-6 relative bg-gradient-to-br from-gray-900 via-black to-gray-900 overflow-hidden"
>
  <!-- Background -->
  <div
    class="absolute inset-0 bg-gradient-to-br from-indigo-50/50 via-white to-purple-50/50 dark:from-gray-900 dark:via-black dark:to-gray-900"
  >
  </div>

  <div class="relative z-10 max-w-5xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        {sectionHeader.title.split(" ").slice(0, -1).join(" ")}
        <span
          class="bg-gradient-to-r from-primary-400 to-primary-600 bg-clip-text text-transparent"
          >{sectionHeader.title.split(" ").pop()}</span
        >
      </h2>
      <p class="text-base text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        {sectionHeader.subtitle}
      </p>
    </div>


    <!-- Mobile: Auto-scroll Carousel | Desktop: Grid -->
    <div class="relative">
      <!-- Mobile Marquee (Hidden on desktop) -->
      <div
        class="md:hidden flex flex-col gap-4 w-full overflow-hidden mask-horizontal pb-4 pt-2 -mx-4 px-4"
      >
        <!-- Mobile Row 1 (Left) -->
        <div class="flex gap-3 w-max animate-marquee-left">
          {
            [...characters.slice(0, 9), ...characters.slice(0, 9)].map(
              (character) => (
                <div
                  class="character-card floating-card group p-2 rounded-xl backdrop-blur-md transition-all duration-300 shadow-xl block w-[160px] flex-shrink-0"
                  data-category={character.category}
                  style={`--theme-color: ${character.themeColor};`}
                >
                  <div class="flex flex-col items-center text-center">
                    {/* Character Image */}
                    <img
                      src={character.image}
                      alt={character.name}
                      class="w-20 h-20 rounded-full mb-2 object-cover"
                      style={`border: 2px solid ${character.themeColor}60;`}
                      loading="lazy"
                    />
                    <h3
                      class="text-base font-semibold mb-1"
                      style={`color: ${character.themeColor}`}
                    >
                      {character.name}
                    </h3>
                    <p class="text-sm font-medium mb-1 text-gray-800 dark:text-gray-200">{character.role}</p>
                    <p class="text-sm text-gray-600 dark:text-gray-300 line-clamp-2">
                      {character.description}
                    </p>
                  </div>
                </div>
              ),
            )
          }
        </div>

        <!-- Mobile Row 2 (Right) -->
        <div class="flex gap-3 w-max animate-marquee-right">
          {
            [...characters.slice(9, 17), ...characters.slice(9, 17)].map(
              (character) => (
                <div
                  class="character-card floating-card group p-2 rounded-xl backdrop-blur-md transition-all duration-300 shadow-xl block w-[160px] flex-shrink-0"
                  data-category={character.category}
                  style={`--theme-color: ${character.themeColor};`}
                >
                  <div class="flex flex-col items-center text-center">
                    {/* Character Image */}
                    <img
                      src={character.image}
                      alt={character.name}
                      class="w-20 h-20 rounded-full mb-2 object-cover"
                      style={`border: 2px solid ${character.themeColor}60;`}
                      loading="lazy"
                    />
                    <h3
                      class="text-base font-semibold mb-1"
                      style={`color: ${character.themeColor}`}
                    >
                      {character.name}
                    </h3>
                    <p class="text-sm font-medium mb-1 text-gray-800 dark:text-gray-200">{character.role}</p>
                    <p class="text-sm text-gray-600 dark:text-gray-300 line-clamp-2">
                      {character.description}
                    </p>
                  </div>
                </div>
              ),
            )
          }
        </div>
      </div>

      <!-- Desktop Marquee (Hidden on mobile) -->
      <div
        class="hidden md:flex flex-col gap-5 w-full overflow-hidden mask-horizontal pb-4 pt-2 -mx-4 px-4 sm:-mx-8 sm:px-8"
      >
        <!-- Row 1 (Right) -->
        <div
          class="flex gap-4 w-max animate-marquee-right hover:[animation-play-state:paused]"
        >
          {
            [...characters.slice(0, 6), ...characters.slice(0, 6)].map(
              (character) => (
                <div
                  class="character-card floating-card group p-2 rounded-xl backdrop-blur-md transition-all duration-300 shadow-xl flex-shrink-0 w-[260px]"
                  data-category={character.category}
                  style={`--theme-color: ${character.themeColor};`}
                >
                  <div class="text-center">
                    <a
                      href={`/c/${character.id}`}
                      class="text-xl font-semibold mb-2 hover:opacity-80 transition-opacity"
                      style={`color: ${character.themeColor}`}
                    >
                      {character.name}
                    </a>
                  </div>
                  <div class="flex justify-center mb-2 mt-2">
                    <div
                      class="w-28 h-28 rounded-full overflow-hidden border-3 transition-all duration-300"
                      style={`border-color: ${character.themeColor}50;`}
                    >
                      <img
                        src={character.image}
                        alt={character.name}
                        class="w-full h-full object-contain"
                        loading="lazy"
                      />
                    </div>
                  </div>
                  <div class="text-center">
                    <p class="text-sm font-medium mb-2 text-gray-800 dark:text-white">
                      {character.role}
                    </p>
                    <p class="text-sm text-gray-600 dark:text-gray-300 line-clamp-3">
                      {character.description}
                    </p>
                  </div>
                </div>
              ),
            )
          }
        </div>

        <!-- Row 2 (Left) -->
        <div
          class="flex gap-4 w-max animate-marquee-left hover:[animation-play-state:paused]"
        >
          {
            [...characters.slice(6, 12), ...characters.slice(6, 12)].map(
              (character) => (
                <div
                  class="character-card floating-card group p-2 rounded-xl backdrop-blur-md transition-all duration-300 shadow-xl flex-shrink-0 w-[260px]"
                  data-category={character.category}
                  style={`--theme-color: ${character.themeColor};`}
                >
                  <div class="text-center">
                    <a
                      href={`/c/${character.id}`}
                      class="text-xl font-semibold mb-2 hover:opacity-80 transition-opacity"
                      style={`color: ${character.themeColor}`}
                    >
                      {character.name}
                    </a>
                  </div>
                  <div class="flex justify-center mb-2 mt-2">
                    <div
                      class="w-28 h-28 rounded-full overflow-hidden border-3 transition-all duration-300"
                      style={`border-color: ${character.themeColor}50;`}
                    >
                      <img
                        src={character.image}
                        alt={character.name}
                        class="w-full h-full object-contain"
                        loading="lazy"
                      />
                    </div>
                  </div>
                  <div class="text-center">
                    <p class="text-sm font-medium mb-2 text-gray-800 dark:text-white">
                      {character.role}
                    </p>
                    <p class="text-sm text-gray-600 dark:text-gray-300 line-clamp-3">
                      {character.description}
                    </p>
                  </div>
                </div>
              ),
            )
          }
        </div>

        <!-- Row 3 (Right) -->
        <div
          class="flex gap-4 w-max animate-marquee-right hover:[animation-play-state:paused]"
        >
          {
            [...characters.slice(12, 17), ...characters.slice(12, 17)].map(
              (character) => (
                <div
                  class="character-card floating-card group p-2 rounded-xl backdrop-blur-md transition-all duration-300 shadow-xl flex-shrink-0 w-[260px]"
                  data-category={character.category}
                  style={`--theme-color: ${character.themeColor};`}
                >
                  <div class="text-center">
                    <a
                      href={`/c/${character.id}`}
                      class="text-xl font-semibold mb-2 hover:opacity-80 transition-opacity"
                      style={`color: ${character.themeColor}`}
                    >
                      {character.name}
                    </a>
                  </div>
                  <div class="flex justify-center mb-2 mt-2">
                    <div
                      class="w-28 h-28 rounded-full overflow-hidden border-3 transition-all duration-300"
                      style={`border-color: ${character.themeColor}50;`}
                    >
                      <img
                        src={character.image}
                        alt={character.name}
                        class="w-full h-full object-contain"
                        loading="lazy"
                      />
                    </div>
                  </div>
                  <div class="text-center">
                    <p class="text-sm font-medium mb-2 text-gray-800 dark:text-white">
                      {character.role}
                    </p>
                    <p class="text-sm text-gray-600 dark:text-gray-300 line-clamp-3">
                      {character.description}
                    </p>
                  </div>
                </div>
              ),
            )
          }
        </div>
      </div>

      <!-- Bottom CTA -->
      <div class="text-center mt-12">
        <!-- <p class="text-gray-300 mb-4">Tidak yakin mau pilih yang mana?</p> -->
        <a
          href="#pricing"
          class="inline-flex items-center gap-2 px-6 py-3 bg-white/50 hover:bg-white/80 dark:bg-white/5 dark:hover:bg-white/10 text-gray-900 dark:text-white font-medium rounded-lg border border-gray-200 hover:border-gray-300 dark:border-white/20 dark:hover:border-white/30 transition-all duration-200 backdrop-blur-sm"
        >
          Lihat Paket
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
      </div>
    </div>


    <style>
      /* Card Styles with Theme Support */
      .character-card {
        /* Dynamic properties */
        border: 1px solid
          color-mix(in srgb, var(--theme-color), transparent 70%);
        box-shadow: 0 4px 20px
          color-mix(in srgb, var(--theme-color), transparent 90%);

        /* Light mode background: Clean white with subtle theme tint */
        background: linear-gradient(
          135deg,
          rgba(255, 255, 255, 0.9) 0%,
          color-mix(in srgb, var(--theme-color), white 90%) 100%
        );
      }

      /* Mobile specific width */
      @media (max-width: 768px) {
        .character-card {
          width: 160px;
        }
      }

      /* Dark Mode Overrides */
      :global(.dark) .character-card {
        border: 1px solid
          color-mix(in srgb, var(--theme-color), transparent 60%);
        box-shadow: 0 4px 20px
          color-mix(in srgb, var(--theme-color), transparent 80%);

        /* Dark mode background: Glassy streak effect */
        background: linear-gradient(
          90deg,
          rgba(255, 255, 255, 0.15) 0%,
          color-mix(in srgb, var(--theme-color), transparent 80%) 50%,
          rgba(255, 255, 255, 0.15) 100%
        );
      }

      /* Hover Effects */
      .character-card:hover {
        transform: translateY(-5px);
        filter: brightness(1.02);
        border-color: color-mix(in srgb, var(--theme-color), transparent 40%);
        box-shadow: 0 10px 30px
          color-mix(in srgb, var(--theme-color), transparent 85%);
      }

      :global(.dark) .character-card:hover {
        box-shadow: 0 8px 30px
          color-mix(in srgb, var(--theme-color), transparent 80%);
      }

      .character-card:hover .w-36 {
        transform: scale(1.05);
      }

      /* Hide scrollbar for mobile carousel - WebKit browsers */
      .overflow-x-auto::-webkit-scrollbar {
        display: none;
      }

      /* Character cards floating animation */
      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @keyframes simpleGlass {
        0%,
        100% {
          background-position: 0% 50%;
        }
        50% {
          background-position: 100% 50%;
        }
      }

      .floating-card {
        background-size: 200% 100%;
        animation: simpleGlass 4s ease-in-out infinite;
      }

      .floating-card:nth-child(2n) {
        animation: simpleGlass 5s ease-in-out infinite reverse;
      }

      .floating-card:nth-child(3n) {
        animation: simpleGlass 6s ease-in-out infinite;
      }

      .floating-card:nth-child(4n) {
        animation: simpleGlass 4.5s ease-in-out infinite reverse;
      }

      .floating-card:hover {
        transform: translateY(-3px);
      }

      /* Hover effects akan menggunakan CSS variables yang diset dari themeColor */
      .floating-card:hover {
        filter: brightness(1.1);
      }

      .floating-card:hover .w-36 {
        transform: scale(1.05);
      }

      /* Marquee Animations */
      .animate-marquee-right {
        animation: marquee-right 40s linear infinite;
      }
      .animate-marquee-left {
        animation: marquee-left 40s linear infinite;
      }

      @keyframes marquee-right {
        from {
          transform: translateX(-50%);
        }
        to {
          transform: translateX(0);
        }
      }

      @keyframes marquee-left {
        from {
          transform: translateX(0);
        }
        to {
          transform: translateX(-50%);
        }
      }

      /* Mask to fade edges of marquee */
      .mask-horizontal {
        mask-image: linear-gradient(
          to right,
          transparent,
          black 10%,
          black 90%,
          transparent
        );
        -webkit-mask-image: linear-gradient(
          to right,
          transparent,
          black 10%,
          black 90%,
          transparent
        );
      }
    </style>
  </div>
</section>
