---
import content from "../data/targetAudience.json";
---

<section id="target-audience" class="py-12 md:py-16 px-6 relative overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-br from-indigo-50/50 via-white to-purple-50/50 dark:from-gray-900 dark:via-black dark:to-gray-900"></div>

  <div class="relative z-10 max-w-5xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-8 md:mb-10">
      <h2 class="text-3xl md:text-4xl font-bold mb-4 text-gray-900 dark:text-white">
        {content.header.title.main}
        <span class="bg-gradient-to-r from-primary-400 to-primary-600 bg-clip-text text-transparent">
          {content.header.title.highlight}
        </span>
      </h2>
      <p class="text-base text-gray-600 dark:text-gray-400 max-w-3xl mx-auto">
        {content.header.description}
      </p>
    </div>

    <!-- Target Groups Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4 mb-8">
      {
        content.targetGroups.map((group) => (
          <div class="group p-4 md:p-5 rounded-xl bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-gray-200 dark:border-white/10 hover:border-primary-500/30 dark:hover:border-primary-500/30 hover:bg-white/80 dark:hover:bg-white/10 transition-all duration-300 flex flex-col h-full">
            <div class={`w-10 h-10 rounded-lg flex items-center justify-center mb-4 border ${group.borderColor} bg-gradient-to-br ${group.bgColor}`}>
              <svg class="w-5 h-5 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={group.icon} />
              </svg>
            </div>
            
            <h3 class="text-lg font-semibold mb-2 text-gray-900 dark:text-white leading-tight">
              {group.title}
            </h3>
            
            <p class="text-gray-600 dark:text-gray-400 mb-4 flex-grow text-sm leading-relaxed">
              {group.description}
            </p>
            
            <ul class="space-y-1.5 mt-auto">
              {group.benefits.map((benefit) => (
                <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-300">
                  <svg class="w-4 h-4 text-primary-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="leading-tight">{benefit}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <!-- Bottom Note -->
    <div class="text-center max-w-3xl mx-auto">
      <div class="p-3 md:p-4 rounded-xl bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-gray-200 dark:border-white/10 flex flex-col sm:flex-row items-center justify-center gap-3">
        <div class="w-8 h-8 rounded-full bg-red-100 dark:bg-red-500/20 border border-red-200 dark:border-red-500/30 flex items-center justify-center shrink-0">
          <span class="text-base">⚠️</span>
        </div>
        <div class="text-left">
          <p class="text-gray-900 dark:text-white font-semibold text-sm mb-0.5">
            {content.bottomNote.text}
          </p>
          <p class="text-gray-600 dark:text-gray-400 text-xs">
            {content.bottomNote.subtext}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
