---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Mita-X | Meta Ads Consultant untuk Bisnis Indonesia">
  <!-- CSS untuk glassy animated border (Sama dengan Hero.astro) -->
  <style>
    @keyframes rotate {
      to {
        --angle: 360deg;
      }
    }
    @property --angle {
      syntax: "<angle>";
      initial-value: 0deg;
      inherits: false;
    }
    .mita-glassy-border {
      position: relative;
      background: transparent !important;
      z-index: 1;
    }
    .mita-glassy-border::before {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: inherit;
      padding: 2px;
      background: linear-gradient(
        var(--angle, 0deg),
        rgba(255, 255, 255, 0.05),
        rgba(99, 32, 238, 0.3),
        rgba(255, 255, 255, 0.1),
        rgba(99, 32, 238, 0.2)
      );
      -webkit-mask:
        linear-gradient(#fff 0 0) content-box,
        linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      pointer-events: none;
      z-index: 0;
      animation: rotate 8s linear infinite;
    }
  </style>

  <!-- Hero Section -->
  <section
    class="relative min-h-screen flex items-center justify-center px-6 py-10 md:py-16 overflow-hidden"
  >
    <!-- Background Elements -->
    <div
      class="absolute inset-0 bg-gradient-to-br from-indigo-50/50 via-white to-purple-50/50 dark:from-gray-900 dark:via-black dark:to-gray-900"
    >
    </div>
    <div
      class="absolute top-20 left-10 w-64 h-64 bg-primary-500/10 rounded-full blur-[100px] animate-pulse-slow"
    >
    </div>
    <div
      class="absolute bottom-20 right-10 w-80 h-80 bg-primary-400/5 rounded-full blur-[120px] animate-float"
    >
    </div>

    <div class="relative z-10 max-w-4xl mx-auto text-center mt-12 md:mt-0">
      <div
        class="inline-flex items-center gap-2 px-2 py-1 rounded-full bg-black/5 dark:bg-white/5 backdrop-blur-sm border border-black/10 dark:border-white/10 mb-4"
      >
        <span class="w-2 h-2 bg-primary-400 rounded-full animate-pulse"></span>
        <span class="text-sm text-gray-600 dark:text-gray-300"
          >AIPEDIA Exclusive Specialist</span
        >
      </div>

      <!-- Mita Icon -->
      <div class="flex items-center justify-center mb-6">
        <img
          src="/character/mita.png"
          alt="Mita - Meta Ads Specialist"
          class="h-24 md:h-28 object-contain drop-shadow-xl"
        />
      </div>

      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
        Meta Ads Consultant
        <br />
        <span
          class="bg-gradient-to-r from-primary-400 to-primary-600 bg-clip-text text-transparent"
          >Terbaik untuk Bisnis Indonesia</span
        >
      </h1>

      <p
        class="text-base md:text-lg text-gray-600 dark:text-gray-300 mb-8 max-w-2xl mx-auto"
      >
        Mita-X mendiagnosis funnel, mengevaluasi landing page, menulis copy
        konversi, dan memberikan aturan scaling. <br />
        <b>Jangan buang budget iklan sebelum didiagnosis.</b>
      </p>

      <!-- CTA Buttons -->
      <div
        class="flex flex-col sm:flex-row gap-3 justify-center items-center mb-12"
      >
        <a
          href="#pricing"
          class="btn-cta group inline-flex items-center gap-2 px-6 py-3 font-medium rounded-xl"
        >
          Dapatkan Mita-X Sekarang
        </a>
        <a
          href="#features"
          class="inline-flex items-center gap-2 px-6 py-3 bg-black/5 dark:bg-white/5 hover:bg-black/10 dark:hover:bg-white/10 text-gray-900 dark:text-white font-medium rounded-lg border border-black/10 dark:border-white/20 hover:border-black/20 dark:hover:border-white/30 transition-all duration-200 backdrop-blur-sm hover:border-primary-500/30"
        >
          Lihat Kemampuannya
        </a>
      </div>

      <!-- Dummy Screenshot Area with exactly Hero.astro styling -->
      <div class="max-w-3xl w-full mx-auto">
        <div
          class="mita-glassy-border p-[2px] rounded-xl bg-gradient-to-r from-black/10 via-black/5 to-primary-500/30 dark:from-white/30 dark:via-white/10 dark:to-primary-500/30"
        >
          <img
            src="https://placehold.co/1200x675/000000/ffffff?text=Screenshot+Mita-X+App"
            alt="Preview Mita-X"
            class="w-full object-contain rounded-xl bg-black block"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Problem Section -->
  <section class="py-12 md:py-16 px-6 relative overflow-hidden">
    <div
      class="absolute inset-0 bg-gradient-to-br from-indigo-50/50 via-white to-purple-50/50 dark:from-gray-900 dark:via-black dark:to-gray-900 opacity-50"
    >
    </div>
    <div class="relative z-10 max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">
          Iklan Meta Anda
          <span
            class="bg-gradient-to-r from-primary-400 to-primary-600 bg-clip-text text-transparent"
            >Sering Boncos?</span
          >
        </h2>
        <p class="text-base text-gray-600 dark:text-gray-400 max-w-3xl mx-auto">
          Mita-X menggunakan kerangka diagnostik berbasis metrik, bukan feeling.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div
          class="group p-6 rounded-xl bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-gray-200 dark:border-white/10 hover:border-primary-500/30 dark:hover:border-primary-500/30 hover:bg-white/80 dark:hover:bg-white/10 transition-all duration-300"
        >
          <h3 class="text-xl font-bold mb-3">CTR Tinggi, Sales Nol</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Masalahnya bukan di iklan, tapi di Landing Page atau Offer. Mita-X
            akan membedahnya layer per layer.
          </p>
        </div>
        <div
          class="group p-6 rounded-xl bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-gray-200 dark:border-white/10 hover:border-primary-500/30 dark:hover:border-primary-500/30 hover:bg-white/80 dark:hover:bg-white/10 transition-all duration-300"
        >
          <h3 class="text-xl font-bold mb-3">Ad Fatigue</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Frekuensi naik, CTR turun perlahan. Mita-X tahu persis kapan harus
            merefresh creative dan kapan hold.
          </p>
        </div>
        <div
          class="group p-6 rounded-xl bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-gray-200 dark:border-white/10 hover:border-primary-500/30 dark:hover:border-primary-500/30 hover:bg-white/80 dark:hover:bg-white/10 transition-all duration-300"
        >
          <h3 class="text-xl font-bold mb-3">Ragu Kapan Scaling</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Budget dinaikkan, performa malah hancur. Mita-X memberikan aturan
            scaling berbasis Learning Phase.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4-in-1 Capabilities -->
  <section id="features" class="py-12 md:py-16 px-6 relative overflow-hidden">
    <div
      class="absolute inset-0 bg-gradient-to-br from-indigo-50/50 via-white to-purple-50/50 dark:from-gray-900 dark:via-black dark:to-gray-900"
    >
    </div>
    <div class="relative z-10 max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">
          Bukan Sekadar
          <span
            class="bg-gradient-to-r from-primary-400 to-primary-600 bg-clip-text text-transparent"
            >Chatbot Biasa</span
          >
        </h2>
        <p class="text-base text-gray-600 dark:text-gray-400 max-w-3xl mx-auto">
          Mita-X dibangun di atas 11 dokumen <i>knowledge base</i> khusus, merangkum
          pengalaman media buying di pasar Indonesia.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div
          class="group p-6 rounded-xl bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-gray-200 dark:border-white/10 hover:border-primary-500/30 dark:hover:border-primary-500/30 hover:bg-white/80 dark:hover:bg-white/10 transition-all duration-300"
        >
          <div class="flex items-center gap-4 mb-3">
            <div
              class="w-10 h-10 rounded-lg flex items-center justify-center border border-primary-300 dark:border-primary-500/30 bg-primary-50 dark:bg-primary-500/10 text-primary-500 dark:text-primary-400 font-bold"
            >
              1
            </div>
            <h3 class="text-xl font-bold">Media Buyer Expert</h3>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Merancang struktur kampanye (Cold vs Retargeting), alokasi budget,
            dan strategi bidding berdasarkan margin profit Anda.
          </p>
        </div>
        <div
          class="group p-6 rounded-xl bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-gray-200 dark:border-white/10 hover:border-primary-500/30 dark:hover:border-primary-500/30 hover:bg-white/80 dark:hover:bg-white/10 transition-all duration-300"
        >
          <div class="flex items-center gap-4 mb-3">
            <div
              class="w-10 h-10 rounded-lg flex items-center justify-center border border-primary-300 dark:border-primary-500/30 bg-primary-50 dark:bg-primary-500/10 text-primary-500 dark:text-primary-400 font-bold"
            >
              2
            </div>
            <h3 class="text-xl font-bold">Copywriter Konversi</h3>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Menciptakan formula Hook, Primary Text, dan Headline yang
            menghentikan scroll, disesuaikan dengan tingkat kesadaran audiens.
          </p>
        </div>
        <div
          class="group p-6 rounded-xl bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-gray-200 dark:border-white/10 hover:border-primary-500/30 dark:hover:border-primary-500/30 hover:bg-white/80 dark:hover:bg-white/10 transition-all duration-300"
        >
          <div class="flex items-center gap-4 mb-3">
            <div
              class="w-10 h-10 rounded-lg flex items-center justify-center border border-primary-300 dark:border-primary-500/30 bg-primary-50 dark:bg-primary-500/10 text-primary-500 dark:text-primary-400 font-bold"
            >
              3
            </div>
            <h3 class="text-xl font-bold">Funnel Analyst</h3>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Menganalisa metrik asli (CTR, CPC, CVR, ROAS) dan membandingkannya
            dengan Benchmark UKM Indonesia untuk mencari titik kebocoran.
          </p>
        </div>
        <div
          class="group p-6 rounded-xl bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-gray-200 dark:border-white/10 hover:border-primary-500/30 dark:hover:border-primary-500/30 hover:bg-white/80 dark:hover:bg-white/10 transition-all duration-300"
        >
          <div class="flex items-center gap-4 mb-3">
            <div
              class="w-10 h-10 rounded-lg flex items-center justify-center border border-primary-300 dark:border-primary-500/30 bg-primary-50 dark:bg-primary-500/10 text-primary-500 dark:text-primary-400 font-bold"
            >
              4
            </div>
            <h3 class="text-xl font-bold">LP Reviewer</h3>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Mengaudit halaman website Anda menggunakan <i
              >5-Section LP Framework</i
            > untuk memastikan penawaran tidak terbuang sia-sia.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- See In Action -->
  <section
    id="see-in-action"
    class="py-12 md:py-16 px-6 relative overflow-hidden"
  >
    <div
      class="absolute inset-0 bg-gradient-to-br from-indigo-50/50 via-white to-purple-50/50 dark:from-gray-900 dark:via-black dark:to-gray-900 opacity-50"
    >
    </div>
    <div class="relative z-10 max-w-5xl mx-auto text-center">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">
          Lihat Mita-X
          <span
            class="bg-gradient-to-r from-primary-400 to-primary-600 bg-clip-text text-transparent"
            >Beraksi</span
          >
        </h2>
        <p class="text-base text-gray-600 dark:text-gray-400 max-w-3xl mx-auto">
          Intip bagaimana Mita-X membedah campaign, mengaudit landing page, dan
          menulis copy iklan yang tajam.
        </p>
      </div>

      <div class="max-w-4xl w-full mx-auto">
        <div
          class="mita-glassy-border p-[2px] rounded-xl bg-gradient-to-r from-black/10 via-black/5 to-primary-500/30 dark:from-white/30 dark:via-white/10 dark:to-primary-500/30"
        >
          <img
            src="https://placehold.co/1200x675/000000/ffffff?text=Screenshot+Mita-X+See+In+Action"
            alt="Mita-X in Action"
            class="w-full object-contain rounded-xl bg-black block"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Product Formats -->
  <section class="py-12 md:py-16 px-6 relative overflow-hidden">
    <div
      class="absolute inset-0 bg-gradient-to-br from-indigo-50/50 via-white to-purple-50/50 dark:from-gray-900 dark:via-black dark:to-gray-900 opacity-50"
    >
    </div>
    <div class="relative z-10 max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">
          Format
          <span
            class="bg-gradient-to-r from-primary-400 to-primary-600 bg-clip-text text-transparent"
            >Multi-Platform</span
          >
        </h2>
        <p class="text-base text-gray-600 dark:text-gray-400 max-w-3xl mx-auto">
          Tersedia dalam berbagai format sesuai dengan alur kerja tim Anda.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div
          class="group p-6 rounded-xl bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-gray-200 dark:border-white/10 hover:border-primary-500/30 dark:hover:border-primary-500/30 hover:bg-white/80 dark:hover:bg-white/10 transition-all duration-300"
        >
          <h3 class="text-xl font-bold mb-2">Custom GPT</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
            5 Mode cerdas: Diagnostic, LP Review, Copy, Planning, dan Chat.
            Akses via ChatGPT Plus.
          </p>
          <img
            src="/vendors/chatgpt-white.png"
            alt="ChatGPT"
            class="h-8 object-contain invert dark:invert-0 opacity-70"
          />
        </div>
        <div
          class="group p-6 rounded-xl bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-gray-200 dark:border-white/10 hover:border-primary-500/30 dark:hover:border-primary-500/30 hover:bg-white/80 dark:hover:bg-white/10 transition-all duration-300"
        >
          <h3 class="text-xl font-bold mb-2">Claude Skills</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
            6 Skill modular. Cocok jika butuh analisa Campaign Audit yang dalam
            dan terstruktur.
          </p>
          <img
            src="/vendors/claude.png"
            alt="Claude"
            class="h-8 object-contain opacity-70"
          />
        </div>
        <div
          class="group p-6 rounded-xl bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-gray-200 dark:border-white/10 hover:border-primary-500/30 dark:hover:border-primary-500/30 hover:bg-white/80 dark:hover:bg-white/10 transition-all duration-300"
        >
          <h3 class="text-xl font-bold mb-2">Codex Plugin</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
            Untuk developer/agensi. Hasilkan Markdown report otomatis dari data
            Meta Ads Anda.
          </p>
          <img
            src="https://placehold.co/100x40/000000/ffffff?text=CODEX"
            alt="Codex"
            class="h-8 object-contain opacity-70 rounded"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing/CTA Section -->
  <section id="pricing" class="py-12 md:py-16 px-6 relative overflow-hidden">
    <div
      class="absolute inset-0 bg-gradient-to-br from-indigo-50/50 via-white to-purple-50/50 dark:from-gray-900 dark:via-black dark:to-gray-900"
    >
    </div>
    <div class="relative z-10 max-w-2xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">
        Berhenti Menebak-nebak.
        <br />
        <span
          class="bg-gradient-to-r from-primary-400 to-primary-600 bg-clip-text text-transparent"
          >Mulai Mendiagnosis.</span
        >
      </h2>
      <p class="text-base text-gray-600 dark:text-gray-400 mb-10">
        Dapatkan akses ke Mita-X dan kelola iklan layaknya agency profesional.
      </p>

      <div
        class="group p-8 rounded-2xl bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-gray-200 dark:border-white/10 hover:border-primary-500/50 dark:hover:border-primary-500/50 hover:bg-white/80 dark:hover:bg-white/10 transition-all duration-300 shadow-xl"
      >
        <h3 class="text-2xl font-bold mb-2">Mita-X Bundle</h3>
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">
          Akses penuh ke semua aset & dokumentasi
        </p>

        <div class="text-4xl font-bold mb-8">
          Rp 97.000 <span
            class="text-lg text-gray-500 dark:text-gray-400 font-normal line-through"
            >Rp 197.000</span
          >
        </div>

        <a
          href="#"
          class="btn-cta group inline-flex items-center justify-center gap-2 px-8 py-4 w-full font-bold rounded-xl mb-4 text-lg"
        >
          Beli Akses Mita-X
        </a>

        <p class="text-xs text-gray-500 dark:text-gray-400">
          Pembayaran sekali. Garansi uang kembali jika hasil diagnosa ngawur.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section id="faq" class="py-12 md:py-16 px-4 relative overflow-hidden">
    <div
      class="absolute inset-0 bg-gradient-to-br from-indigo-50/50 via-white to-purple-50/50 dark:from-gray-900 dark:via-black dark:to-gray-900 opacity-50"
    >
    </div>
    <div class="relative z-10 max-w-3xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">
          <span
            class="bg-gradient-to-r from-primary-400 to-primary-600 bg-clip-text text-transparent"
            >Pertanyaan yang</span
          > Sering Ditanyakan
        </h2>
      </div>

      <div class="space-y-4">
        <!-- FAQ 1 -->
        <div
          class="faq-item p-4 rounded-lg bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-gray-200 dark:border-white/10"
        >
          <button
            class="faq-question w-full flex justify-between items-center text-left"
          >
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
              Apakah saya butuh langganan ChatGPT Plus?
            </h3>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 text-primary-500 transform transition-transform duration-300"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="faq-answer mt-2 hidden">
            <p class="text-base text-gray-600 dark:text-gray-400">
              Ya, untuk mengakses versi Custom GPT dari Mita-X, Anda memerlukan
              langganan ChatGPT Plus aktif. Namun, kami juga menyediakan plugin
              untuk Claude jika Anda menggunakan platform tersebut.
            </p>
          </div>
        </div>
        <!-- FAQ 2 -->
        <div
          class="faq-item p-4 rounded-lg bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-gray-200 dark:border-white/10"
        >
          <button
            class="faq-question w-full flex justify-between items-center text-left"
          >
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
              Apakah Mita-X bisa bantu jalankan iklan secara otomatis?
            </h3>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 text-primary-500 transform transition-transform duration-300"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="faq-answer mt-2 hidden">
            <p class="text-base text-gray-600 dark:text-gray-400">
              Tidak. Mita-X adalah Konsultan Strategi, bukan alat otomasi. Mita
              akan memberitahu Anda APA yang harus diperbaiki dan BAGAIMANA
              caranya (contoh: copy baru, struktur campaign), tapi Anda tetap
              harus mengeksekusinya di Ads Manager.
            </p>
          </div>
        </div>
        <!-- FAQ 3 -->
        <div
          class="faq-item p-4 rounded-lg bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-gray-200 dark:border-white/10"
        >
          <button
            class="faq-question w-full flex justify-between items-center text-left"
          >
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
              Apakah garansinya beneran?
            </h3>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 text-primary-500 transform transition-transform duration-300"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="faq-answer mt-2 hidden">
            <p class="text-base text-gray-600 dark:text-gray-400">
              Tentu. Jika Anda sudah mencoba Mita-X untuk mendiagnosis campaign
              Anda sesuai arahan, dan hasilnya terbukti ngawur atau sama sekali
              tidak membantu dalam 3 hari, silakan klaim garansi refund 100%.
            </p>
          </div>
        </div>
      </div>
    </div>

    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        const faqQuestions = document.querySelectorAll(".faq-question");

        faqQuestions.forEach((question) => {
          question.addEventListener("click", () => {
            const answer = question.nextElementSibling;
            const icon = question.querySelector("svg");

            // Toggle current answer
            answer.classList.toggle("hidden");
            icon.classList.toggle("rotate-180");
          });
        });
      });
    </script>
  </section>
</Layout>
