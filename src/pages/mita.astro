---
import Layout from "../layouts/Layout.astro";

// Data untuk Mita Dedicated Funnel
const pricing = [
  {
    id: "mita_only",
    name: "Mita Only",
    price: "87.000",
    type: "custom_gpt",
    cta: "Ambil Mita",
    url: "https://myr.id/mita-only-87k",
    features: [
      "Mita CustomGPT (11 Meta Ads Knowledge Bases)",
      "6 Mita Skills: Campaign Audit, LP Review, Budget Calculator",
      "Siap pakai di ChatGPT Free/Plus",
    ],
  },
  {
    id: "bundle_17",
    name: "Bundle 17 Spesialis",
    price: "128.000",
    original_price: "348.000",
    badge: "Best Value",
    is_hero: true,
    cta: "Ambil Bundle - Paling Laku",
    url: "https://myr.id/mita-bundle-128k",
    features: [
      "Semua fitur paket Mita (Tetap dapat Mita Skills)",
      "+ 16 AI Spesialis lainnya (CustomGPT Only, tanpa Skills)",
      "Bonus Prompt Library & SOP",
      "Lifetime Update",
    ],
  },
];

const features = [
  {
    title: "Audit Iklan Boncos 5 Menit",
    desc: "Upload metrik Ads Manager, Mita kasih saran matikan / scale.",
    image: "/screenshots/1.png",
  },
  {
    title: "Bikin 3 Angle Iklan Otomatis",
    desc: "Generate copy, headline, CTA siap test A/B.",
    image: "/screenshots/2.png",
  },
  {
    title: "Kalkulator Budget & ROAS",
    desc: "Hitung max CAC dan break-even ROAS otomatis.",
    image: "/screenshots/3.png",
  },
  {
    title: "Review Creative Sebelum Boncos",
    desc: "Feedback hook 3 detik pertama dan visual.",
    image: "/screenshots/4.png",
  },
  {
    title: "Kapan Scale, Kapan Cut",
    desc: "Rule: Learning Limited, Frequency, CTR.",
    image: "/screenshots/5.png",
  },
  {
    title: "24 Jam Siap Pakai",
    desc: "Akses asisten kapan saja saat sedang manage iklan.",
    image: "/screenshots/6.png",
  },
];

const faqs = [
  { q: "Ini prompt atau aplikasi?", a: "CustomGPT, tinggal klik." },
  {
    q: "Bedanya 87k dan 128k?",
    a: "87k cuma Mita (CustomGPT+Skills Mita), 128k dapat Mita + 16 CustomGPT lain. Full Skills 17 Spesialis ada di bump 288k",
  },
];

const platforms = [
  {
    name: "ChatGPT (CustomGPT)",
    desc: "Cocok untuk konsultasi interaktif cepat, tanya-jawab strategi, dan diagnosis adset langsung via ChatGPT Free maupun Plus.",
    img: "/vendors/chatgpt-white.png",
  },
  {
    name: "Claude (Mita Skills)",
    desc: "Cocok untuk audit campaign mendalam, menulis panjang (copywriting), dan membaca report data (CSV) dengan logika tinggi.",
    img: "/vendors/claude.png",
  },
  {
    name: "IDE (Codex Plugin)",
    desc: "Cocok untuk eksekusi workflow developer (auto-generate Markdown Audit Report & SOP) langsung di dalam Cursor / VSCode.",
    img: "/vendors/codex.png",
  },
];
---

<Layout title="Mita | Meta Ads Consultant untuk Bisnis Indonesia">
  <style>
    @keyframes rotate {
      to {
        --angle: 360deg;
      }
    }
    @property --angle {
      syntax: "<angle>";
      initial-value: 0deg;
      inherits: false;
    }
    .mita-glassy-border {
      position: relative;
      background: transparent !important;
      z-index: 1;
    }
    .mita-glassy-border::before {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: inherit;
      padding: 2px;
      background: linear-gradient(
        var(--angle, 0deg),
        rgba(255, 255, 255, 0.05),
        rgba(1, 100, 224, 0.4),
        /* Mita blue #0164e0 */ rgba(255, 255, 255, 0.1),
        rgba(1, 100, 224, 0.2)
      );
      -webkit-mask:
        linear-gradient(#fff 0 0) content-box,
        linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      pointer-events: none;
      z-index: 0;
      animation: rotate 8s linear infinite;
    }
  </style>

  <!-- Hero Section -->
  <section
    class="relative min-h-screen flex items-center justify-center px-6 py-10 md:py-16 overflow-hidden"
  >
    <div
      class="absolute inset-0 bg-gradient-to-br from-blue-50/50 via-white to-sky-50/50 dark:from-gray-900 dark:via-black dark:to-gray-900"
    >
    </div>
    <div
      class="absolute top-20 left-10 w-64 h-64 bg-blue-500/10 rounded-full blur-[100px] animate-pulse-slow"
    >
    </div>
    <div
      class="absolute bottom-20 right-10 w-80 h-80 bg-blue-400/5 rounded-full blur-[120px] animate-float"
    >
    </div>

    <div class="relative z-10 max-w-4xl mx-auto text-center mt-12 md:mt-0">
      <div
        class="inline-flex items-center gap-2 px-2 py-1 rounded-full bg-black/5 dark:bg-white/5 backdrop-blur-sm border border-black/10 dark:border-white/10 mb-4"
      >
        <span class="w-2 h-2 bg-blue-500 rounded-full animate-pulse"></span>
        <span class="text-sm text-gray-600 dark:text-gray-300"
          >Mita by AIPEDIA</span
        >
      </div>

      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
        Iklan Boncos Terus? <br />
        <span
          class="bg-gradient-to-r from-blue-500 to-blue-700 bg-clip-text text-transparent"
          >Biar Mita yang Auditin 5 Menit.</span
        >
      </h1>

      <p
        class="text-base md:text-lg text-gray-600 dark:text-gray-300 mb-8 max-w-2xl mx-auto"
      >
        AI Spesialis Meta Ads yang tau kapan iklan harus dimatikan, kapan harus
        di-scale.
      </p>

      <div class="max-w-xl w-full mx-auto mb-8">
        <div
          class="mita-glassy-border p-[2px] rounded-xl bg-gradient-to-r from-black/10 via-black/5 to-blue-500/30 dark:from-white/30 dark:via-white/10 dark:to-blue-500/30"
        >
          <div
            class="w-full rounded-xl bg-gradient-to-b from-white/50 to-white/10 dark:from-black/50 dark:to-black/10 backdrop-blur-sm p-8 flex justify-center items-center"
          >
            <img
              src="/character/mita.png"
              alt="Mita - Spesialis Iklan Boncos"
              class="h-64 md:h-80 object-contain drop-shadow-2xl"
              loading="lazy"
            />
          </div>
        </div>
      </div>

      <div
        class="flex flex-col sm:flex-row gap-3 justify-center items-center mb-12"
      >
        <a
          href="#pricing"
          class="btn-cta group inline-flex items-center gap-2 px-6 py-3 font-medium rounded-xl"
          onclick="if(typeof fbq !== 'undefined') fbq('track', 'ViewContent');"
        >
          Dapatkan Mita Sekarang
        </a>
        <a
          href="#demo"
          class="inline-flex items-center gap-2 px-6 py-3 bg-black/5 dark:bg-white/5 hover:bg-black/10 dark:hover:bg-white/10 text-gray-900 dark:text-white font-medium rounded-lg border border-black/10 dark:border-white/20 hover:border-black/20 dark:hover:border-white/30 transition-all duration-200 backdrop-blur-sm hover:border-blue-500/30"
        >
          Lihat Demo
        </a>
      </div>
    </div>
  </section>

  <!-- Problem Section -->
  <section class="py-12 md:py-16 px-6 relative overflow-hidden">
    <div
      class="absolute inset-0 bg-gradient-to-br from-blue-50/50 via-white to-sky-50/50 dark:from-gray-900 dark:via-black dark:to-gray-900 opacity-50"
    >
    </div>
    <div class="relative z-10 max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">
          Iklan Meta Anda
          <span
            class="bg-gradient-to-r from-blue-500 to-blue-700 bg-clip-text text-transparent"
            >Sering Boncos?</span
          >
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div
          class="group p-6 rounded-xl bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-red-200 dark:border-red-900/30 transition-all duration-300"
        >
          <div
            class="mb-3 p-2 bg-blue-100 dark:bg-blue-900/30 text-blue-600 rounded-lg inline-block"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="28"
              height="28"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect width="20" height="12" x="2" y="6" rx="2"></rect><circle
                cx="12"
                cy="12"
                r="2"></circle><path d="M6 12h.01M18 12h.01"></path></svg
            >
          </div>
          <h3 class="text-xl font-bold mb-3 text-gray-900 dark:text-white">
            Spend 500rb gak ada yang beli
          </h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Sudah bakar budget harian tapi konversi nihil. Margin keuntungan
            habis hanya untuk bayar traffic.
          </p>
        </div>
        <div
          class="group p-6 rounded-xl bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-red-200 dark:border-red-900/30 transition-all duration-300"
        >
          <div
            class="mb-3 p-2 bg-blue-100 dark:bg-blue-900/30 text-blue-600 rounded-lg inline-block"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="28"
              height="28"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><polyline points="22 17 13.5 8.5 8.5 13.5 2 7"
              ></polyline><polyline points="16 17 22 17 22 11"></polyline></svg
            >
          </div>
          <h3 class="text-xl font-bold mb-3 text-gray-900 dark:text-white">
            CTR bagus tapi gak closing
          </h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Banyak yang klik iklan Anda, tapi saat masuk ke landing page atau
            chat, tidak ada yang membeli.
          </p>
        </div>
        <div
          class="group p-6 rounded-xl bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-red-200 dark:border-red-900/30 transition-all duration-300"
        >
          <div
            class="mb-3 p-2 bg-blue-100 dark:bg-blue-900/30 text-blue-600 rounded-lg inline-block"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="28"
              height="28"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"
              ></path><path d="M12 9v4"></path><path d="M12 17h.01"></path></svg
            >
          </div>
          <h3 class="text-xl font-bold mb-3 text-gray-900 dark:text-white">
            Takut scale, takut boncos
          </h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Saat iklan sedang bagus, Anda ragu untuk menaikkan budget karena
            takut algoritma rusak.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Demo Section -->
  <section id="demo" class="py-12 md:py-16 px-6 relative overflow-hidden">
    <div
      class="absolute inset-0 bg-gradient-to-br from-blue-50/50 via-white to-sky-50/50 dark:from-gray-900 dark:via-black dark:to-gray-900"
    >
    </div>
    <div class="relative z-10 max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">
        Intip Bagaimana
        <span
          class="bg-gradient-to-r from-blue-500 to-blue-700 bg-clip-text text-transparent"
          >Mita Beraksi</span
        >
      </h2>
      <p class="text-base text-gray-600 dark:text-gray-400 mb-8">
        Chat: "Mita, audit adset ini..."
      </p>
      <div
        class="mita-glassy-border p-[2px] rounded-xl bg-gradient-to-r from-black/10 via-black/5 to-blue-500/30 dark:from-white/30 dark:via-white/10 dark:to-blue-500/30"
      >
        <video
          controls
          class="w-full object-cover rounded-xl bg-black block"
          poster="https://placehold.co/1200x675/000000/ffffff?text=Video:+Mita+Audit+Demo"
        >
          <source src="/demo/mita-audit.mp4" type="video/mp4" />
          Browser Anda tidak mendukung video tag.
        </video>
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section id="features" class="py-12 md:py-16 px-6 relative overflow-hidden">
    <div
      class="absolute inset-0 bg-gradient-to-br from-blue-50/50 via-white to-sky-50/50 dark:from-gray-900 dark:via-black dark:to-gray-900 opacity-50"
    >
    </div>
    <div class="relative z-10 max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">
          Kemampuan
          <span
            class="bg-gradient-to-r from-blue-500 to-blue-700 bg-clip-text text-transparent"
            >Spesialis Mita</span
          >
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {
          features.map((feat, i) => (
            <div class="group p-6 rounded-xl bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-gray-200 dark:border-white/10 hover:border-blue-500/30 transition-all duration-300">
              <div class="flex items-center gap-4 mb-3">
                <div class="w-10 h-10 rounded-lg flex items-center justify-center border border-blue-300 dark:border-blue-500/30 bg-blue-50 dark:bg-blue-500/10 text-blue-600 font-bold">
                  {i + 1}
                </div>
                <h3 class="text-xl font-bold">{feat.title}</h3>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-400">
                {feat.desc}
              </p>
              {feat.image && (
                <details class="mt-4 group/accordion">
                  <summary class="cursor-pointer text-xs font-semibold text-blue-600 dark:text-blue-400 hover:text-blue-700 select-none list-none flex items-center gap-1">
                    <span class="group-open/accordion:rotate-90 transition-transform">
                      ▶
                    </span>{" "}
                    Lihat Bukti & Contoh
                  </summary>
                  <div class="mt-3 rounded-lg overflow-hidden border border-gray-200 dark:border-white/10 shadow-sm">
                    <img
                      src={feat.image}
                      alt={feat.title}
                      class="w-full object-cover"
                      loading="lazy"
                    />
                  </div>
                </details>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Multi-Platform Section -->
  <section class="py-12 md:py-16 px-6 relative overflow-hidden">
    <div
      class="absolute inset-0 bg-gradient-to-br from-blue-50/50 via-white to-sky-50/50 dark:from-gray-900 dark:via-black dark:to-gray-900 opacity-50"
    >
    </div>
    <div class="relative z-10 max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">
          Tersedia di
          <span
            class="bg-gradient-to-r from-blue-500 to-blue-700 bg-clip-text text-transparent"
            >Platform Favorit Anda</span
          >
        </h2>
        <p class="text-base text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
          Tidak perlu install aplikasi baru. Mita langsung terintegrasi di
          ekosistem AI yang sudah Anda pakai sehari-hari.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-6xl mx-auto">
        {
          platforms.map((platform) => (
            <div class="p-8 rounded-2xl bg-white/80 dark:bg-white/5 backdrop-blur-sm border border-gray-200 dark:border-white/10 hover:border-blue-500/30 transition-all duration-300 group">
              <div class="flex items-center gap-4 mb-4">
                <img
                  src={platform.img}
                  alt={platform.name}
                  class="w-10 h-10 object-contain group-hover:scale-105 transition-transform"
                />
                <h3 class="text-xl font-bold">{platform.name}</h3>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-400">
                {platform.desc}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section id="pricing" class="py-12 md:py-16 px-6 relative overflow-hidden">
    <div
      class="absolute inset-0 bg-gradient-to-br from-blue-50/50 via-white to-sky-50/50 dark:from-gray-900 dark:via-black dark:to-gray-900"
    >
    </div>
    <div class="relative z-10 max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-10">
        Pilih Paket Spesialis Anda
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-stretch">
        <!-- Mita Only -->
        <div
          class="p-8 rounded-2xl bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-gray-200 dark:border-white/10 flex flex-col"
        >
          <h3 class="text-2xl font-bold mb-2">{pricing[0].name}</h3>
          <p class="text-sm text-gray-500 mb-1">
            Hanya akses AI CustomGPT Mita
          </p>
          <p class="text-sm text-gray-400 mb-4">
            Tanpa akses 16 specialist lain.
          </p>
          <div class="text-5xl font-bold mb-8 text-gray-900 dark:text-white">
            Rp {pricing[0].price}
          </div>

          <ul class="text-left space-y-4 mb-8 flex-1">
            {
              pricing[0].features.map((f) => (
                <li class="flex items-start gap-3">
                  <span class="text-blue-500 font-bold mt-0.5">✓</span>
                  <span class="text-sm text-gray-700 dark:text-gray-300">
                    {f}
                  </span>
                </li>
              ))
            }
          </ul>

          <a
            href={pricing[0].url}
            class="inline-flex items-center justify-center w-full px-6 py-4 bg-black/5 dark:bg-white/5 hover:bg-black/10 dark:hover:bg-white/10 text-gray-900 dark:text-white font-medium rounded-xl border border-black/10 dark:border-white/20 transition-all duration-200 text-lg"
            onclick="if(typeof fbq !== 'undefined') fbq('track', 'InitiateCheckout', {content_name: 'Mita Only', value: 67000, currency: 'IDR'});"
          >
            {pricing[0].cta}
          </a>
        </div>

        <!-- Bundle 17 -->
        <div
          class="relative p-8 rounded-2xl bg-white/90 dark:bg-gray-800 backdrop-blur-sm border-2 border-blue-500 shadow-2xl shadow-blue-500/20 transform md:scale-105 flex flex-col"
        >
          <div
            class="absolute -top-4 left-1/2 -translate-x-1/2 bg-gradient-to-r from-blue-500 to-blue-700 text-white px-4 py-1 rounded-full text-sm font-bold shadow-lg"
          >
            {pricing[1].badge}
          </div>
          <h3 class="text-2xl font-bold mb-2">{pricing[1].name}</h3>
          <p class="text-sm text-gray-500 mb-1">
            Termasuk Mita & 16 AI Lainnya
          </p>
          <p class="text-sm text-gray-400 mb-4">
            Total Eceran: <span class="line-through"
              >Rp {pricing[1].original_price}</span>
          </p>
          <div class="text-5xl font-bold text-gray-900 dark:text-white mb-8">
            Rp {pricing[1].price}
          </div>

          <ul class="text-left space-y-4 mb-8 flex-1">
            {
              pricing[1].features.map((f) => (
                <li class="flex items-start gap-3">
                  <span class="text-blue-500 font-bold mt-0.5">✓</span>
                  <span class="text-sm text-gray-700 dark:text-gray-300 font-medium">
                    {f}
                  </span>
                </li>
              ))
            }
          </ul>

          <a
            href={pricing[1].url}
            class="btn-cta inline-flex items-center justify-center w-full px-6 py-4 font-bold rounded-xl text-lg"
            onclick="if(typeof fbq !== 'undefined') fbq('track', 'InitiateCheckout', {content_name: 'Bundle 17 Spesialis', value: 128000, currency: 'IDR'});"
          >
            {pricing[1].cta}
          </a>

          <p class="text-xs text-center text-gray-500 mt-4">
            *Tersedia bump offer: Full 17 Agent Skills (+160k) saat checkout
          </p>
        </div>
      </div>

      <p
        class="mt-10 text-sm text-gray-500 dark:text-gray-400 font-medium text-center"
      >
        Garansi 7 Hari Uang Kembali. Gak puas? Chat Admin via WhatsApp (link di
        email), dana direfund 100% tanpa ditanya.
      </p>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-12 md:py-16 px-4 relative overflow-hidden">
    <div
      class="absolute inset-0 bg-gradient-to-br from-blue-50/50 via-white to-sky-50/50 dark:from-gray-900 dark:via-black dark:to-gray-900 opacity-50"
    >
    </div>
    <div class="relative z-10 max-w-3xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold mb-6">FAQ</h2>
      </div>

      <div class="space-y-4">
        {
          faqs.map((faq) => (
            <div class="faq-item p-4 rounded-lg bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-gray-200 dark:border-white/10">
              <button class="faq-question w-full flex justify-between items-center text-left">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
                  {faq.q}
                </h3>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4 text-blue-500 transform transition-transform duration-300"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"
                  />
                </svg>
              </button>
              <div class="faq-answer mt-2 hidden">
                <p class="text-base text-gray-600 dark:text-gray-400">
                  {faq.a}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        const faqQuestions = document.querySelectorAll(".faq-question");
        faqQuestions.forEach((question) => {
          question.addEventListener("click", () => {
            const answer = question.nextElementSibling;
            const icon = question.querySelector("svg");
            answer.classList.toggle("hidden");
            icon.classList.toggle("rotate-180");
          });
        });
      });
    </script>
  </section>
</Layout>
