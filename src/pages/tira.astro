---
import Layout from "../layouts/Layout.astro";

// Data untuk Tira x Fina Bundle
const pricing = [
    {
        id: "tira_only",
        name: "TIRA Only",
        price: "87.000",
        type: "custom_gpt",
        cta: "Ambil TIRA",
        url: "https://myr.id/tira-only-87k",
        features: [
            "Tanya jawab pajak unlimited via ChatGPT",
            "Hitung PPh Final 0.5% otomatis dari omzet",
            "Panduan Coretax sampai lapor beres",
        ],
    },
    {
        id: "bundle_tira_fina",
        name: "Bundle TIRA (+ Bonus FINA)",
        price: "128.000",
        original_price: "348.000",
        badge: "Best Value",
        is_hero: true,
        cta: "Ambil Bundle (Lebih Hemat)",
        url: "https://myr.id/tira-fina-bundle-128k",
        features: [
            "Semua fitur TIRA Only",
            "+ AI FINA (Finance Specialist)",
            "+ 15 Spesialis lain (CustomGPT Only)",
            "Template Excel SOP Keuangan",
        ],
    },
];

const features = [
    {
        title: "Konsultasi Pajak UMKM",
        desc: "Tanya apa saja seputar pajak UMKM, TIRA bantu jelaskan dengan bahasa yang mudah dipahami (bukan bahasa undang-undang).",
        image: "/screenshots/1.png",
        specialist: "TIRA",
    },
    {
        title: "Panduan Lapor Pajak",
        desc: "Dapatkan panduan step-by-step cara lapor SPT Tahunan dan Masa secara online tanpa pusing.",
        image: "/screenshots/2.png",
        specialist: "TIRA",
    },
    {
        title: "Hitung PPh Final Otomatis",
        desc: "Cukup berikan angka omzet, TIRA hitungkan PPh Final 0.5% secara instan untuk bisnis kamu.",
        image: "/screenshots/3.png",
        specialist: "TIRA",
    },
    {
        title: "Simulasi Estimasi Denda Pajak",
        desc: "Telat bayar atau lapor? TIRA bantu hitung estimasi potensi denda sesuai Pasal 7 KUP biar bisa antisipasi.",
        image: "/screenshots/4.png",
        specialist: "TIRA",
    },
    {
        title: "Panduan Coretax DJP",
        desc: "Bingung sistem pajak baru? TIRA pandu step-by-step cara pakai Coretax: dari aktivasi akun sampai lapor SPT online.",
        image: "/screenshots/5.png",
        specialist: "TIRA",
    },
    {
        title: "Siap 24 Jam Kapan Saja",
        desc: "Konsultasi pajak kapanpun kamu butuh, bahkan di malam hari saat sedang rekap pembukuan bisnis.",
        image: "/screenshots/6.png",
        specialist: "TIRA",
    },
];

const faqs = [
    {
        q: "Ini prompt atau aplikasi?",
        a: "CustomGPT, tinggal klik di ChatGPT.",
    },
    {
        q: "Bedanya 87k dan 128k?",
        a: "87k cuma TIRA (CustomGPT+Skills TIRA), 128k dapat TIRA + FINA + 15 CustomGPT lain. Full Skills 17 Spesialis ada di bump 288k",
    },
];

const platforms = [
    {
        name: "ChatGPT (CustomGPT)",
        desc: "Cocok untuk konsultasi interaktif cepat, tanya-jawab urusan pajak UMKM dan hitung-hitungan cashflow via ChatGPT Free maupun Plus.",
        img: "/vendors/chatgpt-white.png",
    },
    {
        name: "Claude (Skills)",
        desc: "Cocok untuk membaca report data Meta Ads (CSV) atau laporan laba-rugi keuangan dengan akurasi dan logika tinggi.",
        img: "/vendors/claude.png",
    },
];
---

<Layout title="TIRA | Spesialis Pajak UMKM by AIPEDIA">
    <style>
        @keyframes rotate {
            to {
                --angle: 360deg;
            }
        }
        @property --angle {
            syntax: "<angle>";
            initial-value: 0deg;
            inherits: false;
        }
        .tira-glassy-border {
            position: relative;
            background: transparent !important;
            z-index: 1;
        }
        .tira-glassy-border::before {
            content: "";
            position: absolute;
            inset: 0;
            border-radius: inherit;
            padding: 2px;
            background: linear-gradient(
                var(--angle, 0deg),
                rgba(255, 255, 255, 0.05),
                rgba(229, 57, 53, 0.4),
                /* Tira Red #E53935 */ rgba(255, 255, 255, 0.1),
                rgba(255, 212, 0, 0.4) /* Fina Yellow #FFD400 */
            );
            -webkit-mask:
                linear-gradient(#fff 0 0) content-box,
                linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            pointer-events: none;
            z-index: 0;
            animation: rotate 8s linear infinite;
        }
    </style>

    <!-- Hero Section -->
    <section
        class="relative min-h-screen flex items-center justify-center px-6 py-10 md:py-16 overflow-hidden"
    >
        <div
            class="absolute inset-0 bg-gradient-to-br from-red-50/50 via-white to-yellow-50/50 dark:from-gray-900 dark:via-black dark:to-gray-900"
        >
        </div>
        <div
            class="absolute top-20 left-10 w-64 h-64 bg-red-500/10 rounded-full blur-[100px] animate-pulse-slow"
        >
        </div>
        <div
            class="absolute bottom-20 right-10 w-80 h-80 bg-yellow-400/10 rounded-full blur-[120px] animate-float"
        >
        </div>

        <div class="relative z-10 max-w-4xl mx-auto text-center mt-12 md:mt-0">
            <div
                class="inline-flex items-center gap-2 px-2 py-1 rounded-full bg-black/5 dark:bg-white/5 backdrop-blur-sm border border-black/10 dark:border-white/10 mb-4"
            >
                <span class="w-2 h-2 bg-red-500 rounded-full animate-pulse"
                ></span>
                <span class="text-sm text-gray-600 dark:text-gray-300"
                    >TIRA by AIPEDIA</span
                >
            </div>

            <h1
                class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight"
            >
                Pusing Urusan Pajak UMKM? <br />
                <span
                    class="bg-gradient-to-r from-red-500 to-orange-400 bg-clip-text text-transparent"
                    >Biar TIRA yang Bantuin</span
                >
            </h1>

            <p
                class="text-base md:text-lg text-gray-600 dark:text-gray-300 mb-4 max-w-2xl mx-auto"
            >
                AI Spesialis Pajak UMKM yang siap bantu hitung, lapor, dan jawab
                kebingungan harian seputar pajak bisnismu 24/7
            </p>
            <div
                class="flex flex-wrap justify-center gap-2 md:gap-4 mb-8 text-xs md:text-sm font-medium text-gray-600 dark:text-gray-400"
            >
                <span class="flex items-center gap-1"
                    ><span class="text-green-500 text-base">✓</span> Update Aturan
                    Juli 2026</span
                >
                <span class="flex items-center gap-1"
                    ><span class="text-green-500 text-base">✓</span> Panduan Coretax
                    Step-by-Step</span
                >
                <span class="flex items-center gap-1"
                    ><span class="text-green-500 text-base">✓</span> Bahasa Warung,
                    Bukan Bahasa UU</span
                >
            </div>

            <div class="max-w-xl w-full mx-auto mb-8 relative">
                <div
                    class="tira-glassy-border p-[2px] rounded-xl bg-gradient-to-r from-black/10 via-black/5 to-red-500/30 dark:from-white/30 dark:via-white/10 dark:to-red-500/30"
                >
                    <div
                        class="w-full rounded-xl bg-gradient-to-b from-white/50 to-white/10 dark:from-black/50 dark:to-black/10 backdrop-blur-sm p-8 flex justify-center items-center"
                    >
                        <div class="relative">
                            <img
                                src="/character/tira.png"
                                alt="Tira - Spesialis Pajak UMKM"
                                class="h-48 md:h-80 object-contain drop-shadow-2xl z-10 relative hover:scale-105 transition-transform"
                                loading="lazy"
                            />
                        </div>
                    </div>
                </div>
            </div>

            <div
                class="flex flex-col sm:flex-row gap-3 justify-center items-center mb-6"
            >
                <a
                    href="#pricing"
                    class="btn-cta group inline-flex items-center gap-2 px-6 py-3 font-medium rounded-xl"
                    onclick="if(typeof fbq !== 'undefined') fbq('track', 'ViewContent');"
                >
                    Dapatkan TIRA Sekarang
                </a>
                <a
                    href="#demo"
                    class="inline-flex items-center gap-2 px-6 py-3 bg-black/5 dark:bg-white/5 hover:bg-black/10 dark:hover:bg-white/10 text-gray-900 dark:text-white font-medium rounded-lg border border-black/10 dark:border-white/20 hover:border-black/20 dark:hover:border-white/30 transition-all duration-200 backdrop-blur-sm hover:border-red-500/30"
                >
                    Lihat Demo
                </a>
            </div>

            <p
                class="text-[11px] md:text-xs text-gray-500 dark:text-gray-400 max-w-xl mx-auto opacity-80 pb-8 px-4 text-center"
            >
                *Disclaimer: TIRA adalah AI asisten edukasi pajak, bukan
                konsultan pajak resmi.
            </p>
        </div>
    </section>

    <!-- Problem Section -->
    <section class="py-12 md:py-16 px-6 relative overflow-hidden">
        <div
            class="absolute inset-0 bg-gradient-to-br from-red-50/50 via-white to-yellow-50/50 dark:from-gray-900 dark:via-black dark:to-gray-900 opacity-50"
        >
        </div>
        <div class="relative z-10 max-w-5xl mx-auto">
            <div class="text-center mb-12">
                <h2 class="text-3xl md:text-4xl font-bold mb-6">
                    Urusan Pajak Bisnis <br />
                    <span
                        class="bg-gradient-to-r from-red-500 to-orange-400 bg-clip-text text-transparent"
                        >Bikin Pusing?</span
                    >
                </h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div
                    class="group p-6 rounded-xl bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-red-200 dark:border-red-900/30 transition-all duration-300"
                >
                    <div
                        class="mb-3 p-2 bg-red-100 dark:bg-red-900/30 text-red-600 rounded-lg inline-block"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="28"
                            height="28"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"
                            ></path><path d="M12 9v4"></path><path
                                d="M12 17h.01"></path></svg
                        >
                    </div>
                    <h3
                        class="text-xl font-bold mb-3 text-gray-900 dark:text-white"
                    >
                        Pusing Lapor Pajak
                    </h3>
                    <p class="text-sm text-gray-600 dark:text-gray-400">
                        Masih bingung cara lapor PPh Final UMKM dan SPT Tahunan?
                        TIRA bantu jelaskan aturannya step-by-step tanpa ribet.
                    </p>
                </div>
                <div
                    class="group p-6 rounded-xl bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-red-200 dark:border-red-900/30 transition-all duration-300"
                >
                    <div
                        class="mb-3 p-2 bg-red-100 dark:bg-red-900/30 text-red-600 rounded-lg inline-block"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="28"
                            height="28"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><polyline points="22 17 13.5 8.5 8.5 13.5 2 7"
                            ></polyline><polyline points="16 17 22 17 22 11"
                            ></polyline></svg
                        >
                    </div>
                    <h3
                        class="text-xl font-bold mb-3 text-gray-900 dark:text-white"
                    >
                        Takut Kena Denda
                    </h3>
                    <p class="text-sm text-gray-600 dark:text-gray-400">
                        Sering was-was dapet surat cinta dari kantor pajak
                        karena telat bayar atau salah hitung kewajiban pajak
                        bulanan?
                    </p>
                </div>
                <div
                    class="group p-6 rounded-xl bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-red-200 dark:border-red-900/30 transition-all duration-300"
                >
                    <div
                        class="mb-3 p-2 bg-red-100 dark:bg-red-900/30 text-red-600 rounded-lg inline-block"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="28"
                            height="28"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><rect width="20" height="12" x="2" y="6" rx="2"
                            ></rect><circle cx="12" cy="12" r="2"></circle><path
                                d="M6 12h.01M18 12h.01"></path></svg
                        >
                    </div>
                    <h3
                        class="text-xl font-bold mb-3 text-gray-900 dark:text-white"
                    >
                        Konsultan Pajak Mahal
                    </h3>
                    <p class="text-sm text-gray-600 dark:text-gray-400">
                        Mau tanya-tanya soal pajak bisnis tapi budget belum
                        cukup buat sewa jasa konsultan pajak profesional?
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Comparison Section -->
    <section
        class="py-12 md:py-16 px-6 bg-gray-50 dark:bg-gray-800/30 relative overflow-hidden"
    >
        <div class="relative z-10 max-w-5xl mx-auto">
            <div class="text-center mb-12">
                <h2 class="text-3xl md:text-4xl font-bold mb-4">
                    Kenapa Tanya Pajak ke ChatGPT Biasa Itu <span
                        class="text-red-500">Berbahaya?</span
                    >
                </h2>
                <p
                    class="text-base text-gray-600 dark:text-gray-400 max-w-2xl mx-auto"
                >
                    AI generic dilatih pakai data lama. TIRA sudah di-training
                    khusus pakai peraturan pajak Indonesia terbaru.
                </p>
            </div>

            <div
                class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto"
            >
                <!-- Bad Column -->
                <div
                    class="bg-white/80 dark:bg-gray-800/50 backdrop-blur-sm p-8 rounded-2xl border border-red-200 dark:border-red-900/30 shadow-lg shadow-red-500/5"
                >
                    <div class="flex items-center gap-4 mb-6">
                        <div
                            class="w-12 h-12 bg-red-100 dark:bg-red-900/30 text-red-500 rounded-full flex items-center justify-center font-bold text-2xl"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="24"
                                height="24"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><path d="M18 6 6 18"></path><path
                                    d="m6 6 12 12"></path></svg
                            >
                        </div>
                        <h3 class="text-2xl font-bold">
                            ChatGPT / Gemini Generic
                        </h3>
                    </div>
                    <ul class="space-y-4">
                        <li class="flex items-start gap-3">
                            <span class="text-red-500 font-bold mt-0.5">✗</span>
                            <span class="text-gray-700 dark:text-gray-300"
                                >Jawaban sering pakai aturan pajak lama 2024</span
                            >
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="text-red-500 font-bold mt-0.5">✗</span>
                            <span class="text-gray-700 dark:text-gray-300"
                                >Belum update sistem Coretax DJP yang baru
                            </span>
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="text-red-500 font-bold mt-0.5">✗</span>
                            <span class="text-gray-700 dark:text-gray-300"
                                >Jawab pakai bahasa undang-undang yang ribet</span
                            >
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="text-red-500 font-bold mt-0.5">✗</span>
                            <span class="text-gray-700 dark:text-gray-300"
                                >Hitungan denda sering ngawur</span
                            >
                        </li>
                    </ul>
                </div>

                <!-- Good Column -->
                <div
                    class="bg-white/90 dark:bg-gray-800/90 backdrop-blur-sm p-8 rounded-2xl border-2 border-green-500 shadow-xl shadow-green-500/10 relative transform md:-translate-y-2"
                >
                    <div
                        class="absolute -top-4 left-1/2 -translate-x-1/2 bg-green-500 text-white px-4 py-1 rounded-full text-sm font-bold shadow-lg whitespace-nowrap"
                    >
                        Pilihan Tepat
                    </div>
                    <div class="flex items-center gap-4 mb-6">
                        <div
                            class="w-12 h-12 bg-green-100 dark:bg-green-900/30 text-green-500 rounded-full flex items-center justify-center font-bold text-2xl"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="24"
                                height="24"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><path d="M20 6 9 17l-5-5"></path></svg
                            >
                        </div>
                        <h3 class="text-2xl font-bold">TIRA by AIPEDIA</h3>
                    </div>
                    <ul class="space-y-4">
                        <li class="flex items-start gap-3">
                            <span class="text-green-500 font-bold mt-0.5"
                                >✓</span
                            >
                            <span
                                class="text-gray-700 dark:text-gray-300 font-medium"
                                >Knowledge base update Juli 2026 - include PMK
                                PPh Final 0.5% & alur Coretax terbaru</span
                            >
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="text-green-500 font-bold mt-0.5"
                                >✓</span
                            >
                            <span
                                class="text-gray-700 dark:text-gray-300 font-medium"
                                >Jawab pakai bahasa warung + contoh angka omzet
                                kamu</span
                            >
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="text-green-500 font-bold mt-0.5"
                                >✓</span
                            >
                            <span
                                class="text-gray-700 dark:text-gray-300 font-medium"
                                >Simulasi estimasi denda sesuai Pasal 7 KUP</span
                            >
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Grid -->
    <section id="features" class="py-12 md:py-16 px-6 relative overflow-hidden">
        <div
            class="absolute inset-0 bg-gradient-to-br from-red-50/50 via-white to-yellow-50/50 dark:from-gray-900 dark:via-black dark:to-gray-900 opacity-50"
        >
        </div>
        <div class="relative z-10 max-w-5xl mx-auto">
            <div class="text-center mb-12">
                <h2 class="text-3xl md:text-4xl font-bold mb-6">
                    Kemampuan
                    <span
                        class="bg-gradient-to-r from-red-500 to-orange-400 bg-clip-text text-transparent"
                        >Spesialis TIRA</span
                    >
                </h2>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
                {
                    features.map((feat, i) => (
                        <div class="group p-4 rounded-xl bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-red-200 dark:border-red-900/30 hover:border-red-500/50 transition-all duration-300">
                            <h3 class="text-xl font-bold mb-2">{feat.title}</h3>
                            <p class="text-sm text-gray-600 dark:text-gray-400">
                                {feat.desc}
                            </p>
                            {feat.image && (
                                <details class="mt-4 group/accordion">
                                    <summary class="cursor-pointer text-sm font-semibold select-none list-none flex items-center gap-1 hover:opacity-80 transition-opacity w-fit">
                                        <span class="group-open/accordion:rotate-90 transition-transform bg-gradient-to-r from-red-500 to-orange-400 bg-clip-text text-transparent">
                                            ▶
                                        </span>
                                        <span class="bg-gradient-to-r from-red-500 to-orange-400 bg-clip-text text-transparent">
                                            Lihat Contoh
                                        </span>
                                    </summary>
                                    <div class="mt-3 rounded-lg overflow-hidden border border-gray-200 dark:border-white/10 shadow-sm">
                                        <img
                                            src={feat.image}
                                            alt={feat.title}
                                            class="w-full object-cover"
                                            loading="lazy"
                                        />
                                    </div>
                                </details>
                            )}
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Multi-Platform Section -->
    <section class="py-12 md:py-16 px-6 relative overflow-hidden">
        <div
            class="absolute inset-0 bg-gradient-to-br from-red-50/50 via-white to-yellow-50/50 dark:from-gray-900 dark:via-black dark:to-gray-900 opacity-50"
        >
        </div>
        <div class="relative z-10 max-w-5xl mx-auto">
            <div class="text-center mb-12">
                <h2 class="text-3xl md:text-4xl font-bold mb-4">
                    Tersedia di
                    <span
                        class="bg-gradient-to-r from-red-500 to-orange-400 bg-clip-text text-transparent"
                        >Platform Favorit Anda</span
                    >
                </h2>
                <p
                    class="text-base text-gray-600 dark:text-gray-400 max-w-2xl mx-auto"
                >
                    Tidak perlu install aplikasi baru. TIRA & FINA langsung
                    terintegrasi di ekosistem AI yang sudah Anda pakai
                    sehari-hari.
                </p>
            </div>

            <div class="flex flex-wrap justify-center gap-6 max-w-6xl mx-auto">
                {
                    platforms.map((platform) => (
                        <div class="flex-1 basis-[300px] max-w-[420px] p-8 rounded-2xl bg-white/80 dark:bg-white/5 backdrop-blur-sm border border-gray-200 dark:border-white/10 hover:border-orange-500/30 transition-all duration-300 group">
                            <div class="flex items-center gap-4 mb-4">
                                <img
                                    src={platform.img}
                                    alt={platform.name}
                                    class="w-10 h-10 object-contain group-hover:scale-105 transition-transform"
                                />
                                <h3 class="text-xl font-bold">
                                    {platform.name}
                                </h3>
                            </div>
                            <p class="text-sm text-gray-600 dark:text-gray-400">
                                {platform.desc}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Pricing Section -->
    <section id="pricing" class="py-12 md:py-16 px-6 relative overflow-hidden">
        <div
            class="absolute inset-0 bg-gradient-to-br from-red-50/50 via-white to-yellow-50/50 dark:from-gray-900 dark:via-black dark:to-gray-900"
        >
        </div>
        <div class="relative z-10 max-w-4xl mx-auto text-center">
            <h2 class="text-3xl md:text-4xl font-bold mb-10">
                Pilih Paket Spesialis Anda
            </h2>

